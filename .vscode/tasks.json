{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: g++.exe build Dune_Game",
            "command": "g++.exe",
            "args": [
                "-std=c++11",
                "-Wall",
                "*.cpp",
                "-o",
                "dune_game.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:\\msys64\\mingw64\\bin;${env:PATH}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Builds every .cpp file in the project into dune_game.exe"
        }
    ],
    "version": "2.0.0"
}
